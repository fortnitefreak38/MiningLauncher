{
  "name": "mining-launcher",
  "version": "1.4.0",
  "description": "Mining Launcher – Web-UI, Auto-Update, Telegram-Bot",
  "author": "MiningLauncher",
  "repository": "https://github.com/fortnitefreak38/MiningLauncher",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "node-cron": "^3.0.3",
    "sharp": "^0.35.3"
  },
  "build": {
    "appId": "com.mininglauncher.app",
    "productName": "MiningLauncher",
    "icon": "src/main/icon.png",
    "directories": {
      "output": "dist"
    },
    "publish": null,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/main/icon.png",
      "signAndEditExecutable": false,
      "certificateSubjectName": null
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
